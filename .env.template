# Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API KEYS
# =============================================================================
GOOGLE_API_KEY=your_gemini_api_key_here

# =============================================================================
# DATA DIRECTORIES
# =============================================================================
DATA_DIR=./data
SIMULATED_RUNS_DIR=./data/simulated_runs
EXTERNAL_DATA_DIR=./data/external
FLEET_DATABASE_DIR=./data/fleet_database

# =============================================================================
# SIMULATION PARAMETERS
# =============================================================================
DEFAULT_SAMPLING_RATE_IMU=1000
DEFAULT_SAMPLING_RATE_AUDIO=44100
DEFAULT_SIMULATION_DURATION_SEC=10

# =============================================================================
# PHYSICS PARAMETERS
# =============================================================================
VEHICLE_MASS_KG=1500
WHEELBASE_M=2.5
TRACK_WIDTH_M=1.5
WHEEL_RADIUS_M=0.3

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=./logs/mira_wave.log
ENABLE_DEBUG_PLOTS=false

# =============================================================================
# LANGGRAPH CONFIGURATION
# =============================================================================
MAX_ITERATIONS=20
CHECKPOINT_ENABLED=true
CHECKPOINT_DIR=./checkpoints

# =============================================================================
# PERFORMANCE
# =============================================================================
NUM_WORKERS=4
ENABLE_CACHING=true
CACHE_DIR=./cache
